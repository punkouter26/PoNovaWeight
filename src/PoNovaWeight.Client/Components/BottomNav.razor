@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Navigation

<nav class="fixed bottom-0 left-0 right-0 z-40 lg:hidden bg-white dark:bg-dark-card border-t border-healthy-light dark:border-dark-border shadow-elevation-3">
    <div class="flex items-center justify-around max-w-md mx-auto px-1 py-2">
        <!-- Dashboard -->
        <a href="/" class="@GetNavClass("/")" title="Dashboard">
            <div class="flex flex-col items-center gap-1">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                </svg>
                <span class="text-xs font-medium">Dashboard</span>
            </div>
        </a>

        <!-- Calendar -->
        <a href="/calendar" class="@GetNavClass("/calendar")" title="Calendar">
            <div class="flex flex-col items-center gap-1">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <span class="text-xs font-medium">Calendar</span>
            </div>
        </a>

        <!-- Today (centered, larger) -->
        <a href="@($"/day/{DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")}")" class="@GetNavClass($"/day/{DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")}")" title="Today">
            <div class="flex flex-col items-center gap-1">
                <div class="relative">
                    <div class="w-8 h-8 rounded-lg bg-healthy-primary text-white flex items-center justify-center shadow-healthy text-sm font-bold">
                        @DateTime.Today.Day
                    </div>
                    <div class="absolute -top-1 -right-1 w-2 h-2 bg-healthy-accent rounded-full animate-pulse"></div>
                </div>
                <span class="text-xs font-medium">Today</span>
            </div>
        </a>

        <!-- Settings/Profile-->
        <a href="/settings" class="@GetNavClass("/settings")" title="Settings">
            <div class="flex flex-col items-center gap-1">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <span class="text-xs font-medium">Settings</span>
            </div>
        </a>
    </div>
</nav>

<!-- Add padding to body to account for fixed nav -->
<div class="fixed bottom-0 left-0 right-0 h-20 lg:hidden"></div>

@code {
    private string GetNavClass(string href)
    {
        var currentUri = new Uri(Navigation.Uri);
        var isActive = href == "/" ? 
            currentUri.PathAndQuery == "/" :
            currentUri.PathAndQuery.StartsWith(href);
        
        return $"flex-1 flex justify-center py-3 px-1 text-center transition-colors {(isActive ? "text-healthy-primary border-t-2 border-healthy-primary font-semibold" : "text-healthy-muted hover:text-healthy-primary")}";
    }
}
