@implements IAsyncDisposable

<CascadingValue Value="this">
    @if (IsOpen)
    {
        <!-- Invisible overlay for click-outside detection -->
        <div class="fixed inset-0 z-@(OverlayZIndex)" @onclick="Close"></div>
    }

    <div style="position: relative;">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public Func<Task>? OnClickOutside { get; set; }

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public int OverlayZIndex { get; set; } = 40;

    [Parameter]
    public int ContentZIndex { get; set; } = 50;

    private async Task Close()
    {
        if (OnClickOutside is not null)
        {
            await OnClickOutside();
        }
    }

    ValueTask IAsyncDisposable.DisposeAsync() => ValueTask.CompletedTask;
}
