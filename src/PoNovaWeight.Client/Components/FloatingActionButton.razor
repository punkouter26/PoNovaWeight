@using PoNovaWeight.Shared.DTOs

<div class="fixed bottom-24 right-6 z-30 lg:hidden group">
    <!-- FAB Button -->
    <button @onclick="OnClick"
            class="w-14 h-14 rounded-full bg-gradient-to-br from-healthy-primary to-healthy-dark text-white shadow-elevation-4 hover:shadow-healthy-lg flex items-center justify-center transition-all duration-200 group-hover:scale-110 group-active:scale-95"
            title="Quick log meal">
        
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
    </button>

    <!-- Tooltip -->
    <div class="absolute -top-10 right-1/2 translate-x-1/2 px-3 py-1 bg-gray-900 text-white text-xs rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap font-medium">
        Quick Log
        <div class="absolute top-full right-1/2 translate-x-1/2 w-2 h-2 bg-gray-900 transform rotate-45 -mt-1"></div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnClick { get; set; }
}
