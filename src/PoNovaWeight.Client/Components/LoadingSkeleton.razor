@namespace PoNovaWeight.Client.Components

@if (Variant == "Dashboard")
{
    <div class="lg:grid lg:grid-cols-12 lg:gap-6">
        <div class="lg:col-span-7 space-y-4">
            <div class="bg-gradient-to-br from-healthy-primary/50 to-healthy-dark/50 rounded-2xl shadow-elevation-3 p-5 animate-pulse">
                <div class="flex items-center gap-4">
                    <div class="w-16 h-16 rounded-2xl bg-white/20"></div>
                    <div class="space-y-2">
                        <div class="h-10 w-16 bg-white/20 rounded"></div>
                        <div class="h-4 w-24 bg-white/20 rounded"></div>
                    </div>
                </div>
            </div>

            <div class="bg-white dark:bg-dark-card rounded-2xl shadow-elevation-2 p-5 animate-pulse">
                <div class="h-5 w-32 bg-gray-200 dark:bg-dark-border rounded mb-4"></div>
                <div class="h-40 bg-gray-100 dark:bg-dark-border rounded-xl flex items-end justify-around gap-2 p-3">
                    @for (var i = 0; i < 7; i++)
                    {
                        <div class="w-full bg-gray-200 dark:bg-dark-bg rounded-t-lg" style="height: @(30 + (i * 8))%"></div>
                    }
                </div>
            </div>

            <div class="bg-white dark:bg-dark-card rounded-2xl shadow-elevation-2 p-4 animate-pulse">
                <div class="flex items-center gap-2 mb-4">
                    <div class="w-8 h-8 rounded-lg bg-gray-200 dark:bg-dark-border"></div>
                    <div class="h-4 w-24 bg-gray-200 dark:bg-dark-border rounded"></div>
                </div>
                <div class="grid grid-cols-3 gap-3">
                    @for (var i = 0; i < 6; i++)
                    {
                        <div class="bg-gray-50 dark:bg-dark-border rounded-xl p-3">
                            <div class="flex items-center justify-center gap-2 mb-2">
                                <div class="w-7 h-7 rounded-lg bg-gray-200 dark:bg-dark-bg"></div>
                                <div class="h-5 w-8 bg-gray-200 dark:bg-dark-bg rounded"></div>
                            </div>
                            <div class="h-2 bg-gray-200 dark:bg-dark-bg rounded-full mb-2"></div>
                            <div class="h-3 w-16 mx-auto bg-gray-200 dark:bg-dark-bg rounded"></div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="lg:col-span-5 mt-4 lg:mt-0 space-y-4 animate-pulse">
            <div class="space-y-3">
                <div class="h-4 w-20 bg-gray-200 dark:bg-dark-border rounded"></div>
                @for (var i = 0; i < 7; i++)
                {
                    <div class="bg-white dark:bg-dark-card rounded-2xl shadow-elevation-2 border border-healthy-light dark:border-dark-border p-4">
                        <div class="flex items-center justify-between mb-3">
                            <div class="flex items-center gap-3">
                                <div class="w-11 h-11 bg-gray-200 dark:bg-dark-border rounded-xl"></div>
                                <div>
                                    <div class="h-4 w-10 bg-gray-200 dark:bg-dark-border rounded mb-1"></div>
                                    <div class="h-3 w-14 bg-gray-100 dark:bg-dark-bg rounded"></div>
                                </div>
                            </div>
                            <div class="text-right">
                                <div class="h-5 w-10 bg-gray-200 dark:bg-dark-border rounded mb-1"></div>
                                <div class="h-3 w-12 bg-gray-100 dark:bg-dark-bg rounded"></div>
                            </div>
                        </div>
                        <div class="flex gap-1.5 mb-3">
                            @for (var bar = 0; bar < 6; bar++)
                            {
                                <div class="flex-1 h-2 bg-gray-200 dark:bg-dark-border rounded-full"></div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
else if (Variant == "Calendar")
{
    <div class="space-y-4 animate-pulse">
        <div class="flex items-center justify-center gap-4">
            <div class="w-11 h-11 bg-gray-200 dark:bg-dark-border rounded-xl"></div>
            <div class="h-6 w-32 bg-gray-200 dark:bg-dark-border rounded"></div>
            <div class="w-11 h-11 bg-gray-200 dark:bg-dark-border rounded-xl"></div>
        </div>

        <div class="bg-white dark:bg-dark-card rounded-2xl shadow-elevation-2 border border-healthy-light dark:border-dark-border p-4">
            <div class="grid grid-cols-7 gap-1 mb-2">
                @for (var i = 0; i < 7; i++)
                {
                    <div class="h-6 bg-gray-100 dark:bg-dark-border rounded"></div>
                }
            </div>
            <div class="grid grid-cols-7 gap-1">
                @for (var i = 0; i < 35; i++)
                {
                    <div class="aspect-square bg-gray-100 dark:bg-dark-border rounded-lg"></div>
                }
            </div>
        </div>

        <div class="bg-white dark:bg-dark-card rounded-2xl shadow-elevation-2 border border-healthy-light dark:border-dark-border p-5">
            <div class="flex items-center gap-2 mb-4">
                <div class="w-8 h-8 bg-gray-200 dark:bg-dark-border rounded-lg"></div>
                <div class="h-4 w-28 bg-gray-200 dark:bg-dark-border rounded"></div>
            </div>
            <div class="grid grid-cols-3 gap-4">
                @for (var i = 0; i < 3; i++)
                {
                    <div class="p-3 bg-gray-50 dark:bg-dark-border rounded-xl">
                        <div class="h-8 w-12 bg-gray-200 dark:bg-dark-bg rounded mx-auto mb-2"></div>
                        <div class="h-3 w-16 bg-gray-100 dark:bg-dark-bg rounded mx-auto"></div>
                    </div>
                }
            </div>
        </div>
    </div>
}
else
{
    <div class="space-y-3 lg:max-w-2xl lg:mx-auto animate-pulse">
        <div class="bg-white dark:bg-dark-card rounded-2xl shadow-elevation-2 border border-healthy-light dark:border-dark-border p-4">
            <div class="flex items-center justify-between">
                <div class="w-11 h-11 bg-gray-200 dark:bg-dark-border rounded-xl"></div>
                <div class="text-center">
                    <div class="h-5 w-24 bg-gray-200 dark:bg-dark-border rounded mb-1"></div>
                    <div class="h-3 w-12 bg-gray-100 dark:bg-dark-bg rounded mx-auto"></div>
                </div>
                <div class="w-11 h-11 bg-gray-200 dark:bg-dark-border rounded-xl"></div>
            </div>
        </div>

        <div class="bg-white dark:bg-dark-card rounded-2xl shadow-elevation-2 border border-healthy-light dark:border-dark-border p-4">
            <div class="h-4 w-32 bg-gray-200 dark:bg-dark-border rounded mb-4"></div>
            <div class="lg:grid lg:grid-cols-2 lg:gap-3 space-y-3 lg:space-y-0">
                <div class="space-y-2">
                    @for (var i = 0; i < 3; i++)
                    {
                        <div class="h-14 bg-gray-50 dark:bg-dark-border rounded-xl"></div>
                    }
                </div>
                <div class="space-y-2 mt-2 lg:mt-0">
                    @for (var i = 0; i < 3; i++)
                    {
                        <div class="h-14 bg-gray-50 dark:bg-dark-border rounded-xl"></div>
                    }
                </div>
            </div>
        </div>

        <div class="h-24 bg-white dark:bg-dark-card rounded-2xl shadow-elevation-2 border border-healthy-light dark:border-dark-border"></div>
        <div class="h-56 bg-white dark:bg-dark-card rounded-2xl shadow-elevation-2 border border-healthy-light dark:border-dark-border"></div>
        <div class="h-11 bg-gray-200 dark:bg-dark-border rounded-xl"></div>
    </div>
}

@code {
    [Parameter]
    public string Variant { get; set; } = "DayDetail";
}
