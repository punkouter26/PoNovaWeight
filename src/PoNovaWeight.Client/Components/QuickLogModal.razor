@using PoNovaWeight.Shared.DTOs
@using PoNovaWeight.Shared.Contracts
@inject ApiClient Api

<div class="fixed inset-0 z-50 @(IsOpen ? "block" : "hidden")">
    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" @onclick="Close"></div>

    <!-- Modal -->
    <div class="absolute inset-x-0 bottom-0 bg-white dark:bg-dark-card rounded-t-3xl shadow-elevation-4 max-h-[90vh] overflow-y-auto animate-slide-up">
        <!-- Header -->
        <div class="sticky top-0 bg-white dark:bg-dark-card rounded-t-3xl border-b border-healthy-light dark:border-dark-border px-6 py-4 flex items-center justify-between">
            <h2 class="text-xl font-bold text-healthy-text dark:text-dark-text">Quick Log Meal</h2>
            <button @onclick="Close"
                    class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-gray-100 dark:hover:bg-white/10 transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <!-- Content -->
        <div class="px-6 py-4 space-y-4">
            <!-- Quick Select Recent Meals -->
            @if (RecentMeals.Any())
            {
                <div>
                    <label class="block text-sm font-semibold text-healthy-text dark:text-dark-text mb-3">
                        Recent Meals
                    </label>
                    <div class="space-y-2">
                        @foreach (var meal in RecentMeals.Take(5))
                        {
                            <button class="w-full text-left p-3 rounded-lg border border-healthy-light dark:border-dark-border hover:bg-healthy-light dark:hover:bg-white/5 transition-colors"
                                    @onclick="@(() => SelectMeal(meal))">
                                <div class="font-medium text-healthy-text dark:text-dark-text">@meal.Name</div>
                                <div class="text-xs text-healthy-muted dark:text-dark-muted">@meal.Units units</div>
                            </button>
                        }
                    </div>
                </div>
            }

            <!-- OR Divider -->
            <div class="relative flex items-center gap-3">
                <div class="flex-1 h-px bg-healthy-light dark:bg-dark-border"></div>
                <span class="text-xs text-healthy-muted dark:text-dark-muted font-medium">OR</span>
                <div class="flex-1 h-px bg-healthy-light dark:bg-dark-border"></div>
            </div>

            <!-- Unit Category Selection -->
            <form @onsubmit="HandleSubmit" class="space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-healthy-text dark:text-dark-text mb-2">Category</label>
                    <select @bind="SelectedCategory"
                            class="w-full px-4 py-3 rounded-lg border border-healthy-light dark:border-dark-border bg-white dark:bg-dark-card dark:text-dark-text focus:outline-none focus:ring-2 focus:ring-healthy-primary transition-all">
                        <option value="">Select a category...</option>
                        <option value="Protein">🥚 Protein</option>
                        <option value="Vegetable">🥬 Vegetables</option>
                        <option value="Fruit">🍎 Fruits</option>
                        <option value="Starch">🥔 Starches</option>
                        <option value="Fat">🧈 Fats</option>
                        <option value="Dairy">🧀 Dairy</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-healthy-text dark:text-dark-text mb-2">Units</label>
                    <div class="flex items-center gap-3">
                        <button type="button" @onclick="@(() => Units = Math.Max(1, Units - 1))"
                                class="w-11 h-11 rounded-lg bg-healthy-light dark:bg-white/10 hover:bg-healthy-secondary/20 flex items-center justify-center transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
                            </svg>
                        </button>
                        <div class="flex-1 px-4 py-3 text-center text-2xl font-bold rounded-lg bg-healthy-light dark:bg-white/10 text-healthy-primary dark:text-healthy-secondary">
                            @Units
                        </div>
                        <button type="button" @onclick="@(() => Units = Math.Min(10, Units + 1))"
                                class="w-11 h-11 rounded-lg bg-healthy-light dark:bg-white/10 hover:bg-healthy-secondary/20 flex items-center justify-center transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- Submit Button -->
                <button type="submit" disabled="@(IsSubmitting || string.IsNullOrEmpty(SelectedCategory))"
                        class="w-full py-3 bg-gradient-to-r from-healthy-primary to-healthy-dark text-white rounded-lg font-semibold hover:shadow-healthy-lg transition-all disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2">
                    @if (IsSubmitting)
                    {
                        <svg class="w-4 h-4 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
                        </svg>
                        <span>Logging...</span>
                    }
                    else
                    {
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        <span>Log Units</span>
                    }
                </button>
            </form>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="p-3 bg-semantic-error/10 border border-semantic-error/30 rounded-lg text-sm text-semantic-error dark:text-red-400">
                    @ErrorMessage
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback OnMealLogged { get; set; }

    private List<(string Name, int Units)> RecentMeals { get; set; } = new();
    private string SelectedCategory { get; set; } = "";
    private int Units { get; set; } = 1;
    private bool IsSubmitting { get; set; }
    private string? ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Load recent meals from session/preferences
        RecentMeals = new()
        {
            ("Salmon with rice", 2),
            ("Chicken salad", 2),
            ("Steak with vegetables", 3),
            ("Fish and chips", 2),
            ("Grilled chicken", 1),
        };
    }

    private void SelectMeal((string Name, int Units) meal)
    {
        // Could map meal to category, for now just set units
        Units = meal.Units;
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrEmpty(SelectedCategory))
        {
            ErrorMessage = "Please select a category";
            return;
        }

        try
        {
            IsSubmitting = true;
            ErrorMessage = null;

            // Parse category to UnitCategory enum
            if (Enum.TryParse<UnitCategory>(SelectedCategory, out var category))
            {
                var request = new IncrementUnitRequest
                {
                    Date = DateOnly.FromDateTime(DateTime.Today),
                    Category = category,
                    Delta = Units
                };

                // Call API to log units
                await Api.IncrementUnitAsync(request);

                // Show success feedback
                await OnMealLogged.InvokeAsync();
                await Close();
            }
            else
            {
                ErrorMessage = "Invalid category selected";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to log meal: {ex.Message}";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task Close()
    {
        Units = 1;
        SelectedCategory = "";
        ErrorMessage = null;
        await OnClose.InvokeAsync();
    }
}

