@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Navigation

<!-- Desktop-only sidebar navigation -->
<nav class="hidden lg:flex fixed left-0 top-0 bottom-0 w-64 bg-white dark:bg-dark-card border-r border-healthy-light dark:border-dark-border flex-col">
    
    <!-- Logo/Brand Area -->
    <div class="p-6 border-b border-healthy-light dark:border-dark-border">
        <a href="/" class="flex items-center gap-3 hover:opacity-75 transition-opacity">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-healthy-primary to-healthy-secondary flex items-center justify-center shadow-healthy">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
            </div>
            <div>
                <h1 class="font-bold text-healthy-text dark:text-dark-text">PoNovaWeight</h1>
                <p class="text-xs text-healthy-muted dark:text-dark-muted">Track Your Progress</p>
            </div>
        </a>
    </div>

    <!-- Navigation Links -->
    <div class="flex-1 px-4 py-6 space-y-2">
        <a href="/" class="@GetNavClass("/")" title="Dashboard">
            <div class="flex items-center gap-3 px-4 py-3 rounded-lg transition-all">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                </svg>
                <span class="font-medium">Dashboard</span>
            </div>
        </a>

        <a href="/calendar" class="@GetNavClass("/calendar")" title="Calendar">
            <div class="flex items-center gap-3 px-4 py-3 rounded-lg transition-all">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
                </svg>
                <span class="font-medium">Calendar</span>
            </div>
        </a>

        @{
            var todayPath = $"/day/{DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")}";
        }
        <a href="@todayPath" class="@GetNavClass(todayPath)" title="Today">
            <div class="flex items-center gap-3 px-4 py-3 rounded-lg transition-all">
                <div class="relative">
                    <div class="w-5 h-5 rounded-lg bg-healthy-primary text-white text-xs font-bold flex items-center justify-center shadow-healthy">
                        @DateTime.Today.Day
                    </div>
                    <div class="absolute -top-1 -right-1 w-2 h-2 bg-healthy-accent rounded-full animate-pulse"></div>
                </div>
                <span class="font-medium">Today</span>
            </div>
        </a>

        <a href="/settings" class="@GetNavClass("/settings")" title="Settings">
            <div class="flex items-center gap-3 px-4 py-3 rounded-lg transition-all">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.592c.55 0 1.02.398 1.11.94m-.213 9.203h-.034a7.465 7.465 0 00-4.066 1.087m0 0a6.465 6.465 0 00-2.572 4.039A6.466 6.466 0 006.75 21c3.592 0 6.75-1.688 6.75-3.75 0-1.592-1.343-2.974-3.172-3.434A7.476 7.476 0 0010.5 12.75M12 21c3.592 0 6.75-1.688 6.75-3.75"/>
                </svg>
                <span class="font-medium">Settings</span>
            </div>
        </a>
    </div>

    <!-- User Info Footer -->
    <div class="border-t border-healthy-light dark:border-dark-border p-4">
        <a href="/settings" class="flex items-center gap-3 p-3 rounded-lg hover:bg-healthy-light dark:hover:bg-dark-border transition-colors">
            <div class="w-8 h-8 rounded-full bg-healthy-light dark:bg-dark-border flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-healthy-primary" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 12a3 3 0 100-6 3 3 0 000 6zm0 2c-3.314 0-6 1.507-6 3.364V18a1 1 0 001 1h10a1 1 0 001-1v-1.636C18 15.507 15.314 14 12 14z"/>
                </svg>
            </div>
            <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-healthy-text dark:text-dark-text truncate">Your Profile</p>
                <p class="text-xs text-healthy-muted dark:text-dark-muted truncate">Manage settings</p>
            </div>
        </a>
    </div>
</nav>


@code {
    private string GetNavClass(string href)
    {
        var currentUri = new Uri(Navigation.Uri);
        var targetUri = new Uri(Navigation.BaseUri + href.TrimStart('/'));
        
        var isActive = currentUri.AbsolutePath == targetUri.AbsolutePath ||
                       (href != "/" && currentUri.AbsolutePath.StartsWith(targetUri.AbsolutePath.TrimEnd('/')));
        
        return isActive 
            ? "nav-link-active" 
            : "nav-link-inactive";
    }
}

<style>
    .nav-link-active {
        color: var(--color-primary, #10b981);
    }
    
    .nav-link-inactive {
        color: inherit;
    }
</style>
