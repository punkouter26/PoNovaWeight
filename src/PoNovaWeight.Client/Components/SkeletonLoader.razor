@typeparam TLayout where TLayout : notnull

<div @attributes="AdditionalAttributes">
    @if (Layout == SkeletonLayout.Dashboard)
    {
        <!-- Dashboard skeleton: 7 cards in a grid -->
        <div class="lg:grid lg:grid-cols-12 lg:gap-6">
            <div class="lg:col-span-7 space-y-4">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="bg-white dark:bg-dark-card rounded-2xl shadow-elevation-2 border border-healthy-light dark:border-dark-border p-5 h-64 animate-pulse">
                        <div class="h-6 bg-gray-200 dark:bg-dark-border rounded w-1/3 mb-4"></div>
                        <div class="space-y-2 h-full flex flex-col">
                            <div class="h-4 bg-gray-200 dark:bg-dark-border rounded"></div>
                            <div class="h-4 bg-gray-200 dark:bg-dark-border rounded w-5/6"></div>
                        </div>
                    </div>
                }
            </div>
            <div class="lg:col-span-5 mt-4 lg:mt-0">
                @for (int i = 0; i < 3; i++)
                {
                    <div class="bg-white dark:bg-dark-card rounded-2xl shadow-elevation-2 border border-healthy-light dark:border-dark-border p-4 mb-3 h-32 animate-pulse">
                        <div class="h-5 bg-gray-200 dark:bg-dark-border rounded w-1/4 mb-3"></div>
                        <div class="space-y-2">
                            <div class="h-3 bg-gray-200 dark:bg-dark-border rounded"></div>
                            <div class="h-3 bg-gray-200 dark:bg-dark-border rounded w-4/5"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else if (Layout == SkeletonLayout.Card)
    {
        <!-- Card skeleton: single centered card -->
        <div class="bg-white dark:bg-dark-card rounded-2xl shadow-elevation-2 border border-healthy-light dark:border-dark-border p-5 animate-pulse"
             style="height: @($"{Height}px")">
            <div class="h-6 bg-gray-200 dark:bg-dark-border rounded w-1/4 mb-4"></div>
            <div class="space-y-3">
                @for (int i = 0; i < 3; i++)
                {
                    <div class="h-4 bg-gray-200 dark:bg-dark-border rounded"></div>
                }
            </div>
        </div>
    }
    else if (Layout == SkeletonLayout.DayCard)
    {
        <!-- Day card skeleton: compact horizontal card -->
        <a href="javascript:void(0)" class="block bg-white dark:bg-dark-card rounded-2xl shadow-elevation-2 border border-healthy-light dark:border-dark-border p-4 animate-pulse">
            <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-3">
                    <div class="w-11 h-11 rounded-xl bg-gray-200 dark:bg-dark-border"></div>
                    <div>
                        <div class="h-5 bg-gray-200 dark:bg-dark-border rounded w-12 mb-2"></div>
                        <div class="h-3 bg-gray-200 dark:bg-dark-border rounded w-16"></div>
                    </div>
                </div>
                <div class="text-right">
                    <div class="h-6 bg-gray-200 dark:bg-dark-border rounded w-12 mb-2"></div>
                    <div class="h-3 bg-gray-200 dark:bg-dark-border rounded w-20"></div>
                </div>
            </div>
            <div class="flex gap-1.5 mb-3">
                @for (int i = 0; i < 6; i++)
                {
                    <div class="flex-1 h-2 rounded-full bg-gray-200 dark:bg-dark-border"></div>
                }
            </div>
        </a>
    }
    else if (Layout == SkeletonLayout.Calendar)
    {
        <!-- Calendar skeleton: grid of cells -->
        <div class="bg-white dark:bg-dark-card rounded-2xl shadow-elevation-2 border border-healthy-light dark:border-dark-border p-4 animate-pulse">
            <div class="grid grid-cols-7 gap-2">
                @for (int i = 0; i < 42; i++)
                {
                    <div class="aspect-square bg-gray-200 dark:bg-dark-border rounded-lg"></div>
                }
            </div>
        </div>
    }
    else
    {
        <!-- Custom/generic skeleton -->
        <div class="bg-white dark:bg-dark-card rounded-2xl shadow-elevation-2 border border-healthy-light dark:border-dark-border p-5 animate-pulse"
             style="height: @($"{Height}px"); width: @($"{Width}")">
            <div class="space-y-3">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="h-4 bg-gray-200 dark:bg-dark-border rounded w-@(i % 2 == 0 ? "full" : "5/6")"></div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public SkeletonLayout Layout { get; set; } = SkeletonLayout.Card;

    [Parameter]
    public int Height { get; set; } = 200;

    [Parameter]
    public string Width { get; set; } = "100%";

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
