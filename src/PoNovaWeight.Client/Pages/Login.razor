@page "/login"
@layout EmptyLayout
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using PoNovaWeight.Client.Services
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject IServiceProvider ServiceProvider

<PageTitle>Sign In - PoNovaWeight</PageTitle>

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-healthy-primary/10 via-healthy-bg to-healthy-secondary/10 dark:from-dark-bg dark:via-dark-card dark:to-dark-bg py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
        <!-- Brand Header -->
        <div class="text-center">
            <div class="w-20 h-20 mx-auto mb-4 rounded-2xl bg-gradient-to-br from-healthy-primary to-healthy-dark flex items-center justify-center shadow-elevation-3">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/></svg>
            </div>
            <h1 class="text-3xl font-bold text-healthy-text dark:text-dark-text">
                PoNovaWeight
            </h1>
            <p class="mt-2 text-sm text-healthy-muted dark:text-dark-muted">
                Your personal OMAD food journal
            </p>
        </div>

        <div class="mt-8 space-y-6">
            <div class="bg-white dark:bg-dark-card rounded-2xl shadow-elevation-3 p-8 border border-healthy-light dark:border-dark-border">
                <div class="text-center mb-6">
                    <h2 class="text-xl font-semibold text-healthy-text dark:text-dark-text">Welcome back</h2>
                    <p class="mt-1 text-sm text-healthy-muted dark:text-dark-muted">Sign in to track your progress</p>
                </div>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="mb-4 p-3 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-lg">
                        <p class="text-sm text-red-700 dark:text-red-300">@ErrorMessage</p>
                    </div>
                }

                <div class="space-y-4">
                    @if (_hasGoogleClientId)
                    {
                        <!-- Google OAuth Button -->
                        <button @onclick="LoginWithGoogle"
                                class="w-full flex justify-center items-center gap-3 py-3 px-4 border border-gray-200 dark:border-dark-border rounded-xl shadow-sm bg-white dark:bg-dark-border text-sm font-medium text-gray-700 dark:text-dark-text hover:bg-gray-50 dark:hover:bg-dark-bg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-healthy-primary transition-all duration-200 hover:shadow-elevation-2">
                            <svg class="h-5 w-5" viewBox="0 0 24 24">
                                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                            </svg>
                            Sign in with Google
                        </button>
                    }

                    @if (_hasMicrosoftClientId)
                    {
                        <!-- Microsoft OAuth Button -->
                        <button @onclick="LoginWithMicrosoft"
                                class="w-full flex justify-center items-center gap-3 py-3 px-4 border border-gray-200 dark:border-dark-border rounded-xl shadow-sm bg-white dark:bg-dark-border text-sm font-medium text-gray-700 dark:text-dark-text hover:bg-gray-50 dark:hover:bg-dark-bg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200 hover:shadow-elevation-2">
                            <svg class="h-5 w-5" viewBox="0 0 21 21">
                                <rect x="1" y="1" width="9" height="9" fill="#F25022"/>
                                <rect x="11" y="1" width="9" height="9" fill="#7FBA00"/>
                                <rect x="1" y="11" width="9" height="9" fill="#00A4EF"/>
                                <rect x="11" y="11" width="9" height="9" fill="#FFB900"/>
                            </svg>
                            Sign in with Microsoft
                        </button>
                    }
                    
                    @if (!_hasGoogleClientId && !_hasMicrosoftClientId)
                    {
                        <p class="text-center text-sm text-red-600">
                            No authentication method configured. Set Google:ClientId or Microsoft:ClientId in appsettings.json.
                        </p>
                    }
                </div>
            </div>

            <p class="text-center text-xs text-healthy-muted dark:text-dark-muted">
                By signing in, you agree to our terms of service and privacy policy.
            </p>
        </div>
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }
    
    [Parameter]
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }
    
    private string? ErrorMessage { get; set; }
    private bool _hasGoogleClientId;
    private bool _hasMicrosoftClientId;
    private string? _microsoftClientId;

    protected override void OnInitialized()
    {
        var googleClientId = Configuration["Google:ClientId"];
        _hasGoogleClientId = !string.IsNullOrEmpty(googleClientId) && googleClientId != "YOUR_GOOGLE_CLIENT_ID";
        
        _microsoftClientId = Configuration["Microsoft:ClientId"];
        _hasMicrosoftClientId = !string.IsNullOrEmpty(_microsoftClientId);
        
        if (!string.IsNullOrEmpty(Error))
        {
            ErrorMessage = Error switch
            {
                "oauth_failed" => "Google sign-in failed. Please try again.",
                "access_denied" => "Access was denied. Please try again.",
                _ => "An error occurred during sign-in."
            };
        }
    }

    private void LoginWithGoogle()
    {
        var returnUrl = string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl;
        Navigation.NavigateToLogin("authentication/login");
    }

    private void LoginWithMicrosoft()
    {
        var nonce = Guid.NewGuid().ToString("N");
        var state = Guid.NewGuid().ToString("N");
        var redirectUri = Uri.EscapeDataString(Navigation.BaseUri + "auth/microsoft-callback");
        var authUrl = $"https://login.microsoftonline.com/common/oauth2/v2.0/authorize" +
            $"?client_id={_microsoftClientId}" +
            $"&response_type=id_token" +
            $"&redirect_uri={redirectUri}" +
            $"&scope=openid%20profile%20email" +
            $"&response_mode=fragment" +
            $"&nonce={nonce}" +
            $"&state={state}";
        Navigation.NavigateTo(authUrl, forceLoad: true);
    }
}
